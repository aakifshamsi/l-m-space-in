# Cloudflare Workers Environment Variables
# Copy to .dev.vars for local development

# Cloudflare Configuration
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Session secret for cookie signing (generate a strong random string)
SESSION_SECRET=your-super-secret-session-key-change-in-production

# Admin credentials (default passwords - CHANGE IMMEDIATELY AFTER FIRST LOGIN)
# Owner: Sir Hammad Ahmad
# Admin: aakif@sham.si
OWNER_EMAIL=hammad@example.com
OWNER_PASSWORD=change-me-owner

ADMIN_EMAIL=aakif@sham.si
ADMIN_PASSWORD=change-me-admin

# JWT Secret for API authentication
JWT_SECRET=your-jwt-secret-change-in-production

# ==========================================
# Multi-Site Configuration
# ==========================================

# Site URLs for different deployments
SITE_URL=https://l.m-space.in              # Main link shortener
MASTER_PANEL_URL=https://m-space.in       # Master control panel
EDGY_SITE_URL=https://edgy.frii.site      # Edgy/fun variant

# Site branding (can be overridden per site)
SITE_NAME="Muslim Space Link"
SITE_DESCRIPTION="Official link shortener for Muslim Space"

# ==========================================
# AI Provider Configuration
# ==========================================

# Ollama (Self-hosted LLM) - Primary AI provider
# Install Ollama: https://ollama.ai
# Run: ollama serve
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3

# Ollama Cloud (Hosted API at ollama.ai) - Get key from https://ollama.ai/cloud
OLLAMA_CLOUD_API_KEY=your-ollama-cloud-api-key
OLLAMA_CLOUD_MODEL=llama3

# Cloudflare Workers AI (Edge-native, fastest)
# Get your Account ID from Cloudflare Dashboard
# CF_ACCOUNT_ID is already set in wrangler.toml
CF_API_TOKEN=your-cf-api-token
CF_WORKERS_AI_MODEL=@cf/meta/llama-3-8b-instruct

# OpenRouter (Unified AI API) - Fallback provider
# Get API key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...

# ==========================================
# Advertisement Configuration (Monetag)
# ==========================================
# Get your API key from https://monetag.com
MONETAG_API_KEY=your-monetag-api-key-here

# Enable/disable advertisements (default: true)
ENABLE_ADS=true

# Enable/disable Instagram promotion banner for @edgymemesforworthlessteens (default: true)
EDGYMEMES_INSTA_PROMO=true

# ==========================================
# Email Configuration (Resend)
# ==========================================
# Get your API key from https://resend.com
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ==========================================
# Browser Automation (BrowserBase)
# ==========================================
# For WhatsApp bots, web scraping, automation tasks
# Get API key from https://browserbase.com
BROWSERBASE_API_KEY=your-browserbase-api-key
BROWSERBASE_EMAIL=your-browserbase-project-email

# ==========================================
# WhatsApp Business API Configuration
# ==========================================
# WhatsApp Business API for sending notifications
# Get credentials from: https://business.facebook.com
# Create a WhatsApp Business account and get your Phone Number ID

# WhatsApp Access Token (from Meta Business App)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token

# WhatsApp Phone Number ID (from WhatsApp Business API)
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id

# WhatsApp Verify Token (for webhook verification - set any random string)
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token-change-me

# WhatsApp API Version (default: v18.0)
WHATSAPP_API_VERSION=v18.0